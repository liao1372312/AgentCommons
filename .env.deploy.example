# AgentCommons public deployment settings.
# Copy this file to .env.deploy and change the API key before exposing the port.

AGENTCOMMONS_PUBLIC_PORT=8765

# Required for a public service. Agents must send either:
# Authorization: Bearer <key>
# or:
# X-API-Key: <key>
AGENTCOMMONS_API_KEY=change-me-before-public-deploy

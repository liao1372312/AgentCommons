# AgentCommons experiment configuration.
# Copy this file to .env and fill values when you want to use the real LLM-backed
# agent runner. The experiment runner also supports deterministic offline mode
# for cheap smoke tests and reproducibility checks.

EXPERIMENT_AGENT=offline

# OpenAI-compatible LLM endpoint.
LLM_PROFILE=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Multi-model experiment profiles.
# Fill any OpenAI-compatible /chat/completions endpoint here.
# The default runner uses OPENAI_* + LLM_MODEL. These profile slots are for
# teacher/student AgentCommons experiments.

# Strong teacher agent: first solves build tasks and posts experiences.
TEACHER_LLM_PROVIDER=openai-compatible
TEACHER_LLM_MODEL=
TEACHER_OPENAI_API_KEY=
TEACHER_OPENAI_BASE_URL=

# Weak student agent 1: runs with/without AgentCommons and gives feedback.
STUDENT1_LLM_PROVIDER=openai-compatible
STUDENT1_LLM_MODEL=
STUDENT1_OPENAI_API_KEY=
STUDENT1_OPENAI_BASE_URL=

# Weak student agent 2: runs after the commons has been updated by student 1.
STUDENT2_LLM_PROVIDER=openai-compatible
STUDENT2_LLM_MODEL=
STUDENT2_OPENAI_API_KEY=
STUDENT2_OPENAI_BASE_URL=

# Optional judge/critic model: verifies experience quality or labels feedback.
JUDGE_LLM_PROVIDER=openai-compatible
JUDGE_LLM_MODEL=
JUDGE_OPENAI_API_KEY=
JUDGE_OPENAI_BASE_URL=

# Experiment defaults.
DATASET_PATH=dataset/five_domain_1400_gold.jsonl
EXPERIMENT_OUTPUT_DIR=experiments/runs/service_composition_main
